  "keyFeatures": [
    "Gamified dashboard with XP points, streaks, and level tracking",
    "Challenge catalog — create templates and accept multi-day challenge tracks",
    "Daily task management with CRUD and completion tracking",
    "Progress diary (notes) for active challenges",
    "JWT-based authentication with automatic 401 redirect handling",
    "Dark and light theme support via Styled Components",
    "Zustand global state with localStorage persistence",
    "React Hook Form + Zod schema validation for all forms",
    "Responsive layout with mobile navigation support"
  ],
  "publicApiSurface": [
    "authService.login(email, password)",
    "authService.signup(name, email, password)",
    "challengeService.listTemplates()",
    "challengeService.createTemplate({ title, description, duration_days })",
    "challengeService.deleteTemplate(id)",
    "challengeService.acceptChallenge(templateId)",
    "challengeService.getActiveChallenge()",
    "challengeService.listMyChallenges()",
    "challengeService.completeChallenge(id)",
    "challengeService.abandonChallenge(id)",
    "challengeService.updateNotes(id, notes)",
    "taskService.createTask(data)",
    "taskService.listMyTasks()",
    "taskService.updateTask(taskId, data)",
    "taskService.deleteTask(taskId)",
    "taskService.completeTask(taskId, photoUrl?)",
    "userService.getProfile()",
    "userService.updateProfile(data)",
    "useAuthStore — Zustand store for auth state (setAuth, logout)",
    "useThemeStore — Zustand store for theme toggling"
  ]
}
